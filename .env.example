
# Environment Configuration for MCQ Generator API
# Copy this file to .env and update with your values

# ============================================================================
# REQUIRED: Groq API Configuration
# ============================================================================
# Get your API key from: https://console.groq.com
GROQ_API_KEY="your_groq_api_key_here"

# ============================================================================
# OPTIONAL: API Security (Recommended for Production)
# ============================================================================
# If set, Quickbase must include this key in X-API-Key header
# Generate a strong random key for production
# Example: API_KEY="my-secret-key-123"
API_KEY=

# ============================================================================
# OPTIONAL: CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins
# Use "*" for testing (allows all origins)
# For production, use your Quickbase domain
# Example: ALLOWED_ORIGINS="https://yourcompany.quickbase.com"
ALLOWED_ORIGINS="*"

# ============================================================================
# QUICKBASE API Configuration (for /generate-and-push-mcqs-quickbase)
# ============================================================================
# Quickbase API Endpoint (usually doesn't need to change)
QUICKBASE_API_ENDPOINT="https://api.quickbase.com/v1/records"

# Your Quickbase Realm Hostname
# Example: yourcompany.quickbase.com
QUICKBASE_REALM_HOSTNAME="your_realm_hostname.quickbase.com"

# Quickbase User Token for Authentication
# Get this from Quickbase → My Preferences → Manage User Tokens
# NEVER commit real tokens to GitHub!
QUICKBASE_USER_TOKEN="your_quickbase_user_token_here"

# Target Table ID where MCQ records will be pushed
# Example: bvxbt7fyw
QUICKBASE_TABLE_ID="your_table_id_here"

# ============================================================================
# RENDER.COM DEPLOYMENT NOTES
# ============================================================================
# When deploying to Render.com:
# 1. These values should be set in Render Dashboard → Environment
# 2. DO NOT commit .env file to GitHub (it's in .gitignore)
# 3. Keep .env only for local testing
# 
# Render Environment Variables to Set:
# - GROQ_API_KEY (required)
# - API_KEY (optional, for security)
# - ALLOWED_ORIGINS (optional, set to your Quickbase domain)
# - QUICKBASE_REALM_HOSTNAME (required for push endpoint)
# - QUICKBASE_USER_TOKEN (required for push endpoint)
# - QUICKBASE_TABLE_ID (required for push endpoint)
# - QUICKBASE_API_ENDPOINT (optional, defaults to https://api.quickbase.com/v1/records)

